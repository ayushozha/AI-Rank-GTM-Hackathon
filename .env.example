# SAI (Simular) API — get a key at https://sai.simular.ai (format: sapi_...)
SAI_API_KEY=sapi_your_key_here
# api.sai.simular.ai currently serves a mismatched TLS cert; use the Cloud Run host directly.
SAI_API_BASE=https://simular-cloud-api-149671192594.us-central1.run.app
# Optional: pin a machine ID from GET /v1/agents/machines. Defaults to the first machine.
SAI_MACHINE_ID=
